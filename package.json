{
	"name": "@agentpond/workspace",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@11.4.0",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsc -b && pnpm -r --if-present build",
		"format": "biome format --write . --files-ignore-unknown=true",
		"format:check": "biome format . --files-ignore-unknown=true",
		"lint": "biome lint . --files-ignore-unknown=true",
		"biome:ci": "biome ci . --files-ignore-unknown=true",
		"prepare": "husky",
		"test": "NODE_ENV=test node --test --import tsx tests/*.test.ts && pnpm -r --filter './apps/*' --filter './packages/*' --if-present test",
		"typecheck": "tsc --noEmit --pretty false",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish",
		"ingest": "tsx apps/ingest/src/index.ts",
		"cli": "tsx apps/cli/src/index.ts",
		"perf:sync": "pnpm --filter @agentpond/perf sync"
	},
	"dependencies": {
		"@duckdb/node-api": "^1.5.4-r.1",
		"@opentelemetry/otlp-transformer": "^0.208.0",
		"fastify": "^5.6.2",
		"protobufjs": "^7.6.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@agentpond/aws": "workspace:*",
		"@agentpond/core": "workspace:*",
		"@agentpond/duckdb": "workspace:*",
		"@agentpond/fastify-ingest": "workspace:*",
		"@agentpond/google": "workspace:*",
		"@agentpond/ingest": "workspace:*",
		"@biomejs/biome": "^2.5.0",
		"@changesets/cli": "^2.29.7",
		"@types/node": "^24.10.1",
		"husky": "^9.1.7",
		"jscpd": "^5.0.11",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
