#!/bin/sh
set -eu

if git status --short | grep --quiet '^MM'; then
  printf '%s\n' "ERROR: Some staged files have unstaged changes. Stage or stash them before committing." >&2
  exit 1
fi

pnpm exec biome check --write --staged --only=assist/source/organizeImports --files-ignore-unknown=true --no-errors-on-unmatched
git update-index --again

pnpm exec biome check --write --staged --files-ignore-unknown=true --no-errors-on-unmatched
