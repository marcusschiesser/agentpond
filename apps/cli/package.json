{
	"name": "agentpond",
	"version": "0.3.6",
	"description": "Agent-native CLI for local Langfuse-compatible trace analytics",
	"license": "MIT",
	"type": "module",
	"bin": {
		"agentpond": "./dist/index.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsup",
		"test": "NODE_ENV=test node --test --import tsx tests/*.test.ts",
		"prepack": "node ./scripts/copy-readme.mjs"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/marcusschiesser/agentpond.git",
		"directory": "apps/cli"
	},
	"dependencies": {
		"@agentpond/aws": "workspace:*",
		"@agentpond/core": "workspace:*",
		"@agentpond/duckdb": "workspace:*",
		"@agentpond/fastify-ingest": "workspace:*",
		"@agentpond/google": "workspace:*",
		"@duckdb/node-api": "^1.5.4-r.1",
		"@inquirer/prompts": "8.5.2",
		"commander": "15.0.0",
		"fastify": "^5.6.2",
		"protobufjs": "^7.6.4",
		"zod": "^4.3.6"
	}
}
