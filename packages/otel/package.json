{
	"name": "@agentpond/otel",
	"version": "0.0.0",
	"description": "OpenTelemetry exporter for writing AgentPond traces directly to object storage",
	"license": "MIT",
	"type": "module",
	"files": [
		"dist"
	],
	"types": "./dist/index.d.ts",
	"scripts": {
		"test": "NODE_ENV=test node --test --import tsx tests/*.test.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/marcusschiesser/agentpond.git",
		"directory": "packages/otel"
	},
